# ============================================================
# MSFS Tablet Tracker — configuration
# Copy this file to ".env" and adjust the values.
# ============================================================

# Web server listening port (open it in the Windows firewall)
PORT=8765

# Listening interface. 0.0.0.0 = reachable from the whole LAN.
HOST=0.0.0.0

# Broadcast rate to the tablets, in Hz (1 to 5)
UPDATE_HZ=3

# Your SimBrief Pilot ID (numeric) OR your SimBrief username.
# Found on simbrief.com > Account Settings.
# Can also be set directly in the web interface (⚙ Settings).
SIMBRIEF_ID=

# Free openaip.net API key (optional): enables the VFR tile layer and the
# vector airspaces with alerts. Can also be set from the web interface.
OPENAIP_KEY=
